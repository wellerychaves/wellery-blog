---

---

<header
	class="border-b border-border bg-bg transition-colors sticky top-0 z-50 font-sans select-none"
>
	<nav
		class="max-w-7xl mx-auto px-6 h-header-h flex justify-between items-center h-16"
	>
		<a href="/" class="font-bold text-fg tracking-tight">Wellery.cc</a>

		<div class="flex items-center gap-6 text-sm">
			<a
				href="/sobre"
				class="text-fg-muted hover:text-fg transition-colors"
			>
				Sobre
			</a>

			<button
				id="theme-toggle"
				class="p-2 rounded-lg hover:bg-bg-surface text-fg-muted hover:text-fg transition-colors cursor-pointer touch-manipulation"
				aria-label="Toggle Theme"
			>
				<span id="icon-dark" class="dark:hidden">🌙</span>
				<span id="icon-light" class="hidden dark:inline">☀️</span>
			</button>
		</div>
	</nav>
</header>
<script>
	const toggle = document.getElementById("theme-toggle");

	toggle?.addEventListener("click", () => {
		const isDark = document.documentElement.classList.toggle("dark");
		const theme = isDark ? "dark" : "light";
		localStorage.setItem("theme", theme);
		sessionStorage.setItem("theme", theme);
	});
</script>
